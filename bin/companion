#!/usr/bin/env bash
# Granola → ticker companion daemon.
# Every N seconds asks Claude (with the official Granola MCP) what is happening
# in the current stream session. On topic change: updates the ticker "now" slot
# and fires a full-screen flash with the new topic. The stream plan is built as
# auto-history: when a new stage of the conversation begins, the companion
# appends it via POST /plan/append (past steps ✓, new step ▶, no pending steps).
#
# Prereq: one-time OAuth — in any Claude Code session run /mcp → granola → authenticate.
# Usage: companion start | stop | status | once | list | verify [--meeting-title "..."]
#
# Env:
#   COMPANION_MEETING_TITLE — hint from stream-meta (substring match, case-insensitive)
#   UNDERCAST_STREAM_META   — path to a stream-meta.md; hint parsed from granola_meeting_title:
#   COMPANION_ALLOW_NO_HINT — 1 to run without any hint (otherwise fails loud, see meeting_guard_fail)
#   COMPANION_INTERVAL      — poll interval seconds (default 180)
#   COMPANION_MODEL         — claude model (default haiku)
#
# Hint precedence: --meeting-title flag > COMPANION_MEETING_TITLE > UNDERCAST_STREAM_META
# > last hint persisted in $STATE_DIR/companion.hint (survives separate shell invocations —
# an agent harness that can't `export` across tool calls still gets the hint through here).
# The persisted hint is date-stamped and only honored the same calendar day (`stop` also
# clears it) — otherwise a stale hint would silently "win" on a later stream, same
# failure mode as the original incident this fix exists for. An explicit source
# (--meeting-title / UNDERCAST_STREAM_META) that resolves to nothing is a hard
# failure, not a fallback to the next tier.
set -uo pipefail

BASE="${UNDERCAST_URL:-${TICKER_URL:-http://127.0.0.1:8722}}"
INTERVAL="${COMPANION_INTERVAL:-180}"
MODEL="${COMPANION_MODEL:-haiku}"
STATE_DIR="${UNDERCAST_STATE_DIR:-$HOME/.local/state/undercast}"
TODAY="$(date +%Y-%m-%d)"
mkdir -p "$STATE_DIR"
PIDFILE="$STATE_DIR/companion.pid"
LOGFILE="$STATE_DIR/companion.log"
HINT_FILE="$STATE_DIR/companion.hint"

# --meeting-title "..." — pulled out of argv before the cmd dispatch at the
# bottom of the file, so it works alongside start/once/verify/etc.
MEETING_TITLE_FLAG=""
MEETING_TITLE_FLAG_SET=0
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --meeting-title)
      # bare "--meeting-title" with no following arg: without this check,
      # `shift 2` on a single remaining positional silently does nothing
      # under set -u (no -e) — $1 stays "--meeting-title" and the loop below
      # never terminates (found by adversarial review of the first version).
      if [ $# -lt 2 ]; then
        echo "companion: --meeting-title requires a value" >&2
        exit 1
      fi
      MEETING_TITLE_FLAG="$2"
      MEETING_TITLE_FLAG_SET=1
      shift 2
      ;;
    --meeting-title=*)
      MEETING_TITLE_FLAG="${1#--meeting-title=}"
      MEETING_TITLE_FLAG_SET=1
      shift
      ;;
    *)
      # bash 3.2 (macOS default) throws "unbound variable" on "${args[@]}"
      # when args is empty under set -u — the ${args[@]+...} guard sidesteps it.
      args=(${args[@]+"${args[@]}"} "$1")
      shift
      ;;
  esac
done
set -- ${args[@]+"${args[@]}"}

meta_hint() {
  local meta="$1"
  [ -n "$meta" ] && [ -f "$meta" ] || return 1
  python3 -c '
import re, sys
with open(sys.argv[1], encoding="utf-8") as f:
    for line in f:
        m = re.match(r"^granola_meeting_title:\s*(.+?)\s*(#.*)?$", line)
        if m:
            val = m.group(1).strip()
            if len(val) >= 2 and val[0] == val[-1] and val[0] in "\x27\"":
                val = val[1:-1]
            print(val)
            break
' "$meta"
}

# Hint resolution. Two different "no hint" outcomes are NOT the same thing:
#   - no source given at all -> cascades down to the next tier, and
#     eventually to require_hint's fail-loud/COMPANION_ALLOW_NO_HINT gate.
#   - a source WAS given explicitly (--meeting-title, or UNDERCAST_STREAM_META
#     — including the one undercast auto-discovers) but resolved to nothing
#     -> HINT_ERROR, hard-fail, NO cascade to the persisted-hint tier below.
#     Silently falling through to a stale hint here is exactly how undercast#16
#     happened (companion tracked the wrong meeting, quietly).
MEETING_TITLE=""
HINT_ERROR=""

if [ "$MEETING_TITLE_FLAG_SET" = 1 ]; then
  if [ -n "$MEETING_TITLE_FLAG" ]; then
    MEETING_TITLE="$MEETING_TITLE_FLAG"
  else
    HINT_ERROR="--meeting-title was given an empty value"
  fi
elif [ -n "${COMPANION_MEETING_TITLE:-}" ]; then
  MEETING_TITLE="$COMPANION_MEETING_TITLE"
elif [ -n "${UNDERCAST_STREAM_META:-}" ]; then
  MEETING_TITLE="$(meta_hint "$UNDERCAST_STREAM_META")"
  [ -z "$MEETING_TITLE" ] && HINT_ERROR="UNDERCAST_STREAM_META=$UNDERCAST_STREAM_META has no granola_meeting_title: (missing file or field)"
fi

# Last tier: a hint persisted by an earlier, separate invocation (e.g.
# `verify` in its own shell call, `start` reading it back with no env) —
# valid only within the same calendar day. Without the date check this file
# never goes empty again after the first run and the whole fail-loud
# contract goes dead (adversarial review finding).
if [ -z "$MEETING_TITLE" ] && [ -z "$HINT_ERROR" ] && [ -f "$HINT_FILE" ]; then
  hint_date="$(sed -n '1p' "$HINT_FILE" 2>/dev/null)"
  if [ "$hint_date" = "$TODAY" ]; then
    MEETING_TITLE="$(tail -n +2 "$HINT_FILE" 2>/dev/null)"
  fi
fi

# Persist what we resolved, date-stamped, so a later separate invocation
# picks it up without a re-export. Never persists on HINT_ERROR (MEETING_TITLE
# stays empty in that case) — a broken explicit source must not overwrite a
# still-valid earlier hint.
[ -n "$MEETING_TITLE" ] && { printf '%s\n' "$TODAY"; printf '%s' "$MEETING_TITLE"; } > "$HINT_FILE"

# mode=persist (default) explicitly tees into LOGFILE — for callers that run
# before/outside the daemon's nohup redirection (start's pre-fork check, once,
# verify). mode=loop is plain stderr — used from inside run_loop, whose stderr
# is already `nohup ... 2>&1`-redirected into LOGFILE by `start`; teeing there
# too would double-write every line.
require_hint() {
  local action="$1" mode="${2:-persist}" msg
  if [ -n "$HINT_ERROR" ]; then
    msg="refusing to $action — hint source given but invalid: $HINT_ERROR"
    if [ "$mode" = loop ]; then echo "$(date +%H:%M:%S) companion: $msg" >&2
    else echo "$(date +%H:%M:%S) companion: $msg" | tee -a "$LOGFILE" >&2; fi
    return 1
  fi
  [ -n "$MEETING_TITLE" ] && return 0
  if [ "${COMPANION_ALLOW_NO_HINT:-0}" = "1" ]; then
    msg="WARNING — $action without a meeting hint (COMPANION_ALLOW_NO_HINT=1), any meeting today can be picked"
    if [ "$mode" = loop ]; then echo "$(date +%H:%M:%S) companion: $msg" >&2
    else echo "$(date +%H:%M:%S) companion: $msg" | tee -a "$LOGFILE" >&2; fi
    return 0
  fi
  msg="refusing to $action — no meeting hint (set COMPANION_MEETING_TITLE, --meeting-title, or UNDERCAST_STREAM_META; override with COMPANION_ALLOW_NO_HINT=1)"
  if [ "$mode" = loop ]; then echo "$(date +%H:%M:%S) companion: $msg" >&2
  else echo "$(date +%H:%M:%S) companion: $msg" | tee -a "$LOGFILE" >&2; fi
  return 1
}

pick_meeting_from_table() {
  local table="$1"
  MEETING_TITLE="$MEETING_TITLE" TODAY="$TODAY" python3 -c '
import os, re, sys
hint = os.environ.get("MEETING_TITLE", "").strip().lower()
today = os.environ.get("TODAY", "").strip()
raw = 0        # non-empty, non-NO_MEETINGS lines the model printed
mismatched = 0 # of those, parsed fine but a different date than today
rows = []
for line in sys.stdin:
    line = line.strip()
    if not line or line.startswith("```") or line.upper().startswith("NO_MEETINGS"):
        continue
    raw += 1
    m = re.match(r"^(\d{4}-\d{2}-\d{2})\s*\|\s*(\d{1,2}:\d{2})\s*\|\s*(.+?)\s*\|\s*([0-9a-f-]{36})\s*$", line, re.I)
    if not m:
        continue
    d, t, title, mid = m.group(1), m.group(2), m.group(3).strip(), m.group(4)
    if today and d != today:
        mismatched += 1
        continue
    h, mn = map(int, t.split(":"))
    rows.append((h * 60 + mn, title, mid))
if not rows:
    # Distinguish a genuine "no meetings" (raw == 0, model itself said
    # NO_MEETINGS / printed nothing) from "the model returned rows but none
    # survived parsing/date filtering" — the latter is a format or Granola-date
    # problem, not an empty calendar, and looks identical to NO_MEETING to the
    # caller unless we say so here.
    if raw:
        print(f"pick_meeting: model returned {raw} row(s), 0 matched today ({today}) after format/date filtering ({mismatched} date-mismatched) — check table format or Granola dates", file=sys.stderr)
    sys.exit(1)
rows.sort(key=lambda r: r[0], reverse=True)
if hint:
    matched = [r for r in rows if hint in r[1].lower()]
    if not matched:
        print(f"pick_meeting: {len(rows)} meeting(s) today but none matched hint {hint!r}", file=sys.stderr)
        sys.exit(1)
    rows = matched
title, mid = rows[0][1], rows[0][2]
print(f"{title} | {mid}")
' <<<"$table"
}

resolve_meeting() {
  local table picked attempt=0
  while [ "$attempt" -lt 3 ]; do
    attempt=$((attempt + 1))
    table="$(call_claude "$(list_prompt)")" || continue
    picked="$(pick_meeting_from_table "$table")" && { echo "$picked"; return 0; }
    sleep 2
  done
  return 1
}

base_prompt() {
  local meeting_line="$1"
  local title id
  title="${meeting_line% | *}"
  id="${meeting_line##* | }"
  cat <<EOF
Use Granola MCP get_meeting_transcript for meeting id: $id (title: "$title").
Read the tail of the transcript — the last 2-3 minutes. Identify the DOMINANT topic.
If the transcript is empty, answer exactly: NO_MEETING

Output MEETING line first (required):
MEETING: $title | $id
EOF
}

list_prompt() {
  cat <<EOF
Use Granola MCP list_meetings for today ($TODAY).
Print a table sorted by start time descending (latest first).
One meeting per line, format exactly:
DATE | TIME | TITLE | ID
DATE in YYYY-MM-DD, TIME in 24h local time. Only meetings whose DATE is $TODAY belong here.
If no meetings today, print: NO_MEETINGS
EOF
}

current_now() {
  curl -sf "$BASE/state" | python3 -c 'import json,sys
items = json.load(sys.stdin).get("items", [])
print(next((i["text"] for i in items if i.get("type") == "now"), ""))' 2>/dev/null
}

plan_context() {
  curl -sf "$BASE/state" | python3 -c 'import json,sys
plan = json.load(sys.stdin).get("plan") or {}
steps = plan.get("steps") or []
for s in steps:
    print(f"- {s[\"text\"]}")
print("CUR=" + next((s["text"] for s in steps if s["status"] == "current"), ""))' 2>/dev/null
}

call_claude() {
  local prompt="$1"
  claude -p "$prompt" --model "$MODEL" --allowedTools "mcp__granola__*" 2>/dev/null
}

parse_meeting_line() {
  local out="$1"
  echo "$out" | sed -n 's/^MEETING:[[:space:]]*//p' | tail -1
}

meeting_guard_fail() {
  local meeting_line="$1"
  [ -z "$MEETING_TITLE" ] && return 1
  [ -z "$meeting_line" ] && return 0
  python3 -c 'import sys
hint, line = sys.argv[1].lower(), sys.argv[2].lower()
sys.exit(1 if hint in line else 0)' "$MEETING_TITLE" "$meeting_line"
}

build_update_prompt() {
  local meeting_line="$1"
  local ctx cur_stage stages
  ctx="$(plan_context)"
  cur_stage="$(echo "$ctx" | sed -n 's/^CUR=//p')"
  stages="$(echo "$ctx" | grep -v '^CUR=' || true)"

  if [ -n "$stages" ]; then
    cat <<EOF
$(base_prompt "$meeting_line")

Stream stages so far (auto-history, the last one is the current stage):
$stages

Then answer with EXACTLY three lines (MEETING + STAGE + NOW). Keep protocol keywords literal; write titles in the language spoken in the meeting:
MEETING: <repeat the meeting line above exactly>
STAGE: <SAME if unchanged from "$cur_stage"; otherwise new stage title — 5 words max, not repeating stages above>
NOW: <one line, 90 characters max — verb + essence, no quotes>
EOF
  else
    cat <<EOF
$(base_prompt "$meeting_line")

No stream stages recorded yet — this is the very beginning.

Then answer with EXACTLY three lines (MEETING + STAGE + NOW). Keep protocol keywords literal; write titles in the language spoken in the meeting:
MEETING: <repeat the meeting line above exactly>
STAGE: <first stage title — 5 words max>
NOW: <one line, 90 characters max — verb + essence, no quotes>
EOF
  fi
}

apply_response() {
  local out="$1"
  local meeting_line line stage moved cur_stage
  meeting_line="$(parse_meeting_line "$out")"
  cur_stage="$(plan_context | sed -n 's/^CUR=//p')"

  if meeting_guard_fail "$meeting_line"; then
    echo "$(date +%H:%M:%S) companion: meeting mismatch (hint: $MEETING_TITLE, got: ${meeting_line:-?}), skipping" >&2
    return 2
  fi

  line="$(echo "$out" | sed -n 's/^NOW:[[:space:]]*//p' | tail -1)"
  stage="$(echo "$out" | sed -n 's/^STAGE:[[:space:]]*//p' | tail -1 | sed 's/[[:space:]]*$//')"

  if [ -z "$line" ] && [ -z "$stage" ]; then
    echo "$(date +%H:%M:%S) companion: no NOW:/STAGE: in response, skipping — raw: $(echo "$out" | head -c 200)" >&2
    return 1
  fi

  moved=""
  if [ -n "$stage" ] && [ "$(echo "$stage" | tr '[:upper:]' '[:lower:]')" != "same" ] \
    && python3 -c 'import sys; sys.exit(0 if sys.argv[1].strip().lower() != sys.argv[2].strip().lower() else 1)' "$stage" "$cur_stage"; then
    payload=$(python3 -c 'import json,sys; print(json.dumps({"text": sys.argv[1].strip()}))' "$stage")
    curl -sf -X POST -H 'content-type: application/json' -d "$payload" "$BASE/plan/append" >/dev/null 2>&1 && moved=1
    if [ -n "$moved" ]; then
      flash=$(python3 -c 'import json,sys; print(json.dumps("▶ " + sys.argv[1].strip()))' "$stage")
      curl -sf -X POST -H 'content-type: application/json' -d "{\"mode\":\"flash\",\"title\": $flash,\"seconds\":7}" "$BASE/screen" >/dev/null
      echo "$(date +%H:%M:%S) plan: new stage — $stage"
    fi
  fi

  if [ -n "$line" ] && [ "$line" != "$(current_now)" ]; then
    text=$(python3 -c 'import json,sys; print(json.dumps(sys.argv[1][:120]))' "$line")
    curl -sf -X POST -H 'content-type: application/json' -d "{\"text\": $text}" "$BASE/now" >/dev/null
    if [ -z "$moved" ]; then
      curl -sf -X POST -H 'content-type: application/json' -d "{\"mode\":\"flash\",\"title\": $text,\"seconds\":8}" "$BASE/screen" >/dev/null
    fi
    echo "$(date +%H:%M:%S) now: $line"
  else
    echo "$(date +%H:%M:%S) companion: topic unchanged"
  fi
}

update_once() {
  local out prompt meeting_line resolved
  resolved="$(resolve_meeting)" || {
    echo "$(date +%H:%M:%S) companion: no meeting today, skipping"
    return 0
  }
  meeting_line="$resolved"
  prompt="$(build_update_prompt "$meeting_line")"
  out="$(call_claude "$prompt")"
  if [ -z "$out" ]; then
    echo "$(date +%H:%M:%S) companion: empty response from claude" >&2
    return 1
  fi
  if echo "$out" | grep -q "NO_MEETING"; then
    echo "$(date +%H:%M:%S) companion: no meeting today, skipping"
    return 0
  fi
  meeting_line="$(parse_meeting_line "$out")"
  [ -n "$meeting_line" ] && echo "$(date +%H:%M:%S) meeting: $meeting_line"
  apply_response "$out"
}

list_meetings() {
  call_claude "$(list_prompt)"
}

verify_once() {
  local out prompt meeting_line line stage rc=0 resolved
  resolved="$(resolve_meeting)" || {
    echo "verify: NO_MEETING — no suitable meeting today"
    return 1
  }
  meeting_line="$resolved"
  echo "picked: $meeting_line"
  prompt="$(build_update_prompt "$meeting_line")"
  out="$(call_claude "$prompt")"
  if [ -z "$out" ]; then
    echo "verify: empty response from claude" >&2
    return 1
  fi
  if echo "$out" | grep -q "NO_MEETING"; then
    echo "verify: NO_MEETING — transcript empty"
    return 1
  fi
  meeting_line="$(parse_meeting_line "$out")"
  line="$(echo "$out" | sed -n 's/^NOW:[[:space:]]*//p' | tail -1)"
  stage="$(echo "$out" | sed -n 's/^STAGE:[[:space:]]*//p' | tail -1 | sed 's/[[:space:]]*$//')"
  echo "MEETING: ${meeting_line:-?}"
  echo "STAGE: ${stage:-?}"
  echo "NOW: ${line:-?}"
  if meeting_guard_fail "$meeting_line"; then
    echo "verify: FAIL — hint \"$MEETING_TITLE\" not in meeting title" >&2
    rc=1
  else
    echo "verify: ok"
  fi
  return "$rc"
}

run_loop() {
  echo "companion: loop every ${INTERVAL}s (model: $MODEL)"
  [ -n "$MEETING_TITLE" ] && echo "companion: meeting hint: $MEETING_TITLE"
  while true; do
    # require_hint's own warning fires every iteration here (not just at
    # startup) — this line is what shows up in `tail -f companion.log`.
    if require_hint "update" loop; then
      update_once || true
    fi
    sleep "$INTERVAL"
  done
}

cmd="${1:-status}"
case "$cmd" in
  once|--once)
    require_hint "run once" || exit 1
    update_once
    ;;
  list|--list)
    list_meetings
    ;;
  verify|--verify)
    require_hint "verify" || exit 1
    verify_once
    ;;
  start)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "already running (pid $(cat "$PIDFILE"))"
      exit 0
    fi
    require_hint "start" || exit 1
    nohup "$0" __loop >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo "ok: companion started (pid $!), log: $LOGFILE"
    ;;
  __loop)
    run_loop
    ;;
  stop)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      kill "$(cat "$PIDFILE")" && echo "ok: companion stopped"
    else
      echo "not running"
    fi
    rm -f "$PIDFILE"
    # Clear the persisted hint too — the next `start` must resolve its own
    # hint (fresh stream-meta.md / explicit source), not inherit this stream's.
    rm -f "$HINT_FILE"
    ;;
  status)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "running (pid $(cat "$PIDFILE")), interval ${INTERVAL}s"
      [ -n "$MEETING_TITLE" ] && echo "meeting hint: $MEETING_TITLE"
      tail -3 "$LOGFILE" 2>/dev/null || true
    else
      echo "stopped"
    fi
    ;;
  *)
    echo "usage: companion start|stop|status|once|list|verify [--meeting-title \"...\"]" >&2
    exit 1
    ;;
esac